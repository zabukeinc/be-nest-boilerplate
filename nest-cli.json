{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "plugins": [
      {
        "name": "@nestjs/swagger",
        "options": {
          "classValidatorShim": true,
          "introspectComments": true
        }
      }
    ],
    "webpack": {
      "paths": {
        "@shared/*": ["src/@shared/*"],
        "@modules/*": ["src/modules/*"],
        "@config": ["src/@shared/config"]
      }
    }
  }
}
